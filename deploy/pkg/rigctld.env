# rigctld settings for virtual-flex (conffile — edits survive upgrades).
# K4_HOST is your K4's mDNS name or IP, and must match [ptt.k4cat] host in
# config.toml. The K4 answers mDNS for its own hostname (pattern K4-SN<serial>,
# shown in the K4's Network menu), so the .local name is DHCP-proof — no static
# IP or reservation needed. Needs libnss-mdns + avahi-daemon (this package pulls
# them in). Use a raw IP instead if mDNS is blocked on your LAN.
RIG_MODEL=2047
K4_HOST=K4-SNxxxxx.local
K4_CAT_PORT=9200
RIGCTLD_PORT=4532
